{
  channels: {
    facebook: {
      enabled: true,
      name: "Leaderbot",
      pageId: "<FACEBOOK_PAGE_ID>",
      pageAccessToken: "<FACEBOOK_PAGE_ACCESS_TOKEN>",
      appSecret: "<FACEBOOK_APP_SECRET>",
      verifyToken: "<FACEBOOK_VERIFY_TOKEN>",
      // Public entry: anyone who messages the Page can start a basic chat.
      // Keep privileged tools, private memory, deploys, git, and filesystem
      // access restricted outside this channel config.
      dmPolicy: "open",
      allowFrom: ["*"]
    }
  }
}
