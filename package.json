{
  "name": "@dj-shortcut/facebook",
  "version": "2026.6.11",
  "private": true,
  "description": "OpenClaw Facebook channel plugin",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dj-Shortcut/openclaw-facebook.git"
  },
  "bugs": {
    "url": "https://github.com/Dj-Shortcut/openclaw-facebook/issues"
  },
  "homepage": "https://github.com/Dj-Shortcut/openclaw-facebook#readme",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "docs",
    "examples"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/channel-plugin-api.d.ts",
      "default": "./dist/channel-plugin-api.js"
    },
    "./runtime": {
      "types": "./dist/runtime-api.d.ts",
      "default": "./dist/runtime-api.js"
    },
    "./setup": {
      "types": "./dist/setup-entry.d.ts",
      "default": "./dist/setup-entry.js"
    },
    "./configured-state": {
      "types": "./dist/configured-state.d.ts",
      "default": "./dist/configured-state.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "node ./scripts/run-vitest.mjs",
    "prepare": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "check": "npm run build && npm test && npm run pack:dry",
    "openclaw:update": "node scripts/update-openclaw.mjs",
    "openclaw:login": "node scripts/openclaw-login.mjs",
    "openclaw:validate": "node scripts/validate-openclaw-runtime.mjs",
    "release:validate-versions": "node scripts/validate-release-versions.mjs",
    "openclaw:release-check": "npm run openclaw:validate && npm run release:validate-versions && npm run check",
    "messenger:smoke-template": "node scripts/messenger-smoke-checklist.mjs --template",
    "messenger:smoke-validate": "node scripts/messenger-smoke-checklist.mjs --validate",
    "gateway:deploy": "fly deploy -a leaderbot-openclaw-gateway",
    "image-gen:install": "pnpm install --dir apps/image-gen --lockfile-dir apps/image-gen --frozen-lockfile",
    "image-gen:check": "pnpm --dir apps/image-gen check",
    "image-gen:test": "pnpm --dir apps/image-gen test",
    "image-gen:build": "pnpm --dir apps/image-gen build",
    "image-gen:deploy": "cd apps/image-gen && fly deploy -a leaderbot-fb-image-gen",
    "fallow": "npx --yes fallow@2.27.0 --root .",
    "fallow:list": "npx --yes fallow@2.27.0 --root . list",
    "fallow:production": "npx --yes fallow@2.27.0 --root . --production",
    "fallow:report": "mkdir -p .fallow && npx --yes fallow@2.27.0 --root . -f json > .fallow/report.json && node scripts/normalize-fallow-report.mjs --root . .fallow/report.json",
    "fallow:report:production": "mkdir -p .fallow && npx --yes fallow@2.27.0 --root . --production -f json > .fallow/report-production.json && node scripts/normalize-fallow-report.mjs --root . .fallow/report-production.json",
    "fallow:summary": "npx --yes fallow@2.27.0 --root . --summary --score",
    "check:product-boundaries": "node scripts/check-product-boundaries.mjs"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "openclaw": "^2026.6.11",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    },
    "install": {
      "clawhubSpec": "clawhub:@dj-shortcut/facebook",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.11"
    },
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "runtimeSetupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "facebook",
      "label": "Facebook",
      "aliases": [
        "messenger",
        "fb",
        "fbm"
      ],
      "selectionLabel": "Facebook (Page Messenger)",
      "detailLabel": "Facebook Page",
      "docsPath": "/channels/facebook",
      "docsLabel": "facebook",
      "blurb": "Facebook Page Messenger DMs via Meta webhooks.",
      "systemImage": "message.fill",
      "preferOver": [
        "messenger"
      ],
      "exposure": {
        "configured": true,
        "setup": true,
        "docs": true
      },
      "quickstartAllowFrom": true,
      "configuredState": {
        "specifier": "./configured-state",
        "exportName": "hasFacebookConfiguredState"
      }
    }
  }
}
